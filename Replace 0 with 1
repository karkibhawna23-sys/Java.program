import java.util.Scanner;

class ReplaceZero
{
    public static void main(String args[])
    {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number: ");
        int num = sc.nextInt();

        String s;
        s= Integer.toString(num);
        s = s.replace('0','1');

        System.out.println("Output: " + s);
    }
}
